@startuml DI_Wizard_Diagram
title DI Selvbetjeningsportal - Wizard Flow (State Diagram)

skinparam backgroundColor #FAFAFA
skinparam state {
  BackgroundColor #F5F5F5
  BorderColor #2C3E50
  FontColor #2C3E50
  FontSize 12
}

[*] --> S1

state "STEP 1: CVR opslag og bekræftelse" as S1 {
  [*] --> S1_1: CVR input
  S1_1 --> S1_2: CVR opsummering
  S1_2 --> S1_3 <<choice>>: CVR korrekt?
  S1_3 --> S1_4: Ja → Email bekræftelse
  S1_3 --> S1_Error: Nej → Link til virk.dk
  S1_4 --> [*]
  S1_Error --> [*]
}

S1 --> S2

state "STEP 2: Branche" as S2 {
  [*] --> S2_1: Bekræft branche
  S2_1 --> [*]
}

S2 --> S3

state "STEP 3: Ønsker og behov" as S3 {
  [*] --> S3_1: Vælg service
  S3_1 --> S3_2 <<choice>>
  S3_2 --> S3_Andet: Andet
  S3_2 --> S3_Flag1: Overenskomst valgt
  S3_2 --> S3_Flag2: Ikke valgt
  S3_2 --> S3_Flag3: Blandet
  S3_Andet: Beskriv behov (fritekst)
  S3_Flag1: Flag: Arbejdsgiver
  S3_Flag2: Flag: Branchemedlem
  S3_Flag3: Flag: Blandet
  S3_Andet --> [*]
  S3_Flag1 --> [*]
  S3_Flag2 --> [*]
  S3_Flag3 --> [*]
}

S3 --> S4

state "STEP 4: Ansatte" as S4 {
  [*] --> S4_1: Antal ansatte i virksomheden?
  S4_1 --> S4_2 <<choice>>
  S4_2 --> S4_Skip: 0 ansatte → Spring til Step 5
  S4_2 --> S4_Type: 1+ ansatte → Type og lønsum
  S4_Type --> S4_Tier <<choice>>: Determine tier
  S4_Tier --> S4_Tier1: 1-9 → Mikromedlem
  S4_Tier --> S4_Tier2: 10-49 → SMV-medlem
  S4_Tier --> S4_Tier3: 50+ → Erhvervsmedlem
  S4_Skip --> [*]
  S4_Tier1 --> [*]
  S4_Tier2 --> [*]
  S4_Tier3 --> [*]
}

S4 --> S5

state "STEP 5: Overenskomst screening" as S5 {
  [*] --> S5_1 <<choice>>: Har virksomheden en overenskomst?
  S5_1 --> S5_Nej: Nej → Ingen overenskomst (Non-OVK spor)
  S5_1 --> S5_Ved: Ved ikke → Kontakt DI (Onboarding-støtte)
  S5_1 --> S5_Ja: Ja → Nuværende overenskomst
  
  S5_Ja --> S5_Type <<choice>>: Type?
  S5_Type --> S5_Dir: Direkte → Fagforbund
  S5_Type --> S5_Anden: Anden org → Kontakt DI
  S5_Dir --> S5_Upload: Upload overenskomst → Flag: Etableret AG
  
  S5_Nej --> [*]
  S5_Ved --> [*]
  S5_Anden --> [*]
  S5_Upload --> [*]
}

S5 --> S6

state "STEP 6: Branchefællesskaber" as S6 {
  [*] --> S6_1: Valg af branchefællesskaber
  S6_1 --> S6_2 <<choice>>: Utilfreds?
  S6_2 --> S6_Yes: Ja → Kontakt DI
  S6_2 --> [*]: Nej
  S6_Yes --> [*]
}

S6 --> S7

state "STEP 7: Medlemskab og tildeling" as S7 {
  [*] --> S7_1: Kombiner Tier + Flag + Overenskomst
  S7_1 --> S7_2: Vis anbefalet type
  S7_2 --> S7_3: Bekræft medlemskab
  S7_3 --> S7_4 <<choice>>: Byggaranti?
  S7_4 --> S7_5 <<choice>>: Ønskes stadig DI-medl.?
  S7_5 --> S7_Stop: Nej → Afslut
  S7_5 --> [*]: Ja
  S7_Stop --> [*]
}

S7 --> S8

state "STEP 8: Kontaktpersoner" as S8 {
  [*] --> S8_1: Primær HR-kontakt
  S8_1 --> S8_2: Lønsums-kontakt
  S8_2 --> S8_3: Anden tegningsberettiget
  S8_3 --> S8_4: Faktura (email / betalingsservice)
  S8_4 --> [*]
}

S8 --> S9

state "STEP 9: Opsummering" as S9 {
  [*] --> S9_1: Godkend og accepter betingelser
  S9_1 --> [*]
}

S9 --> S10

state "STEP 10: MitID verificering" as S10 {
  [*] --> S10_1: MitID verificering
  S10_1 --> [*]
}

S10 --> S11

state "STEP 11: Bekræftelse og medlemstype" as S11 {
  [*] --> S11_1: Anmodning om indmeldelse
  S11_1 --> S11_2 <<choice>>: Medlemstype?
  S11_2 --> S11_Assoc: Associeret
  S11_2 --> S11_AG: Arbejdsgiver
  S11_2 --> S11_Branch: Branche
  S11_2 --> S11_Full: Fuldmedlem
  
  S11_Assoc --> S11_Success: Velkommen i DI
  S11_AG --> S11_Success
  S11_Branch --> S11_Success
  S11_Full --> S11_Success
  
  S11_Success --> [*]
}

S11 --> [*]

@enduml
